{
  "name": "zeno",
  "private": true,
  "version": "0.1.0",
  "description": "Zeno Electron app",
  "main": "main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite --config vite.config.mjs\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build --config vite.config.mjs",
    "preview": "vite preview --config vite.config.mjs",
    "build": "npm run build:renderer && electron-builder",
    "dist": "npm run build:renderer && electron-builder --win",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.2.0",
    "concurrently": "^9.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "tailwindcss": "^4.2.0",
    "vite": "^8.0.3",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.zeno.app",
    "productName": "Zeno",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/**/*",
      "preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "build/zeno_icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Zeno"
    }
  }
}
